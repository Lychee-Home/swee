# Copy this to .env in the same directory as main.py
# chmod 600 .env once filled in — it holds secrets.

# --- Discord bot ---
DISCORD_BOT_TOKEN=your_bot_token_here
GUILD_ID=123456789012345678
ADMIN_ROLE_ID=123456789012345678

# --- Discord channels ---
# Optional — leave unset/blank to disable Discord -> game chat relay
RELAY_CHANNEL_ID=123456789012345678
STATS_CHANNEL_ID=123456789012345678
ACTIVITY_CHANNEL_ID=123456789012345678
ALERTS_CHANNEL_ID=123456789012345678
ADMIN_CHANNEL_ID=123456789012345678
COMMANDS_CHANNEL_ID=123456789012345678
BOT_UPDATES_CHANNEL_ID=123456789012345678

# --- Palworld REST API ---
REST_HOST=127.0.0.1
REST_PORT=8212
REST_USER=admin
REST_PASSWORD=changemetoo

# --- RAM auto-restart (optional) ---
# Automatically restart the palworld service when host RAM usage crosses
# this percentage. Leave unset to disable the feature entirely.
# RAM_RESTART_THRESHOLD_PCT=90
# RAM_RESTART_COOLDOWN_MIN=15
# Seconds to broadcast an in-game + Discord warning before restarting the server — used by
# the RAM auto-restart, and by /restart and /update.
# RAM_RESTART_WARNING_SEC=60

# --- Player history (optional) ---
# Max offline players shown in the stats embed, most-recently-seen first.
# OFFLINE_PLAYERS_LIMIT=10

# --- Release announcements (optional) ---
# Repo the bot polls for new GitHub Releases to announce in BOT_UPDATES_CHANNEL_ID.
# Leave unset/blank to disable release polling entirely.
GITHUB_REPO=byroncustodio/swee
# Required if GITHUB_REPO is private: a token with read access to it (fine-grained PAT with
# "Contents: Read-only" on that repo, or a classic PAT with "repo" scope). Unauthenticated
# requests to the GitHub API 404 on private repos, so release checks silently fail without this.
# GITHUB_TOKEN=

# --- Pal catch recap feed (optional) ---
# Base URL of the palsave-api service (a separate repo/deployment) that watches the Palworld
# server's backup rotation and exposes new-pal events. Leave unset/blank to disable palfeed
# entirely.
# PALFEED_SERVICE_URL=http://127.0.0.1:8787
# Discord channel for pal catch highlight posts. Required if PALFEED_SERVICE_URL is set.
# PALFEED_CHANNEL_ID=123456789012345678

# --- Palworld settings change alert ---
# Absolute path to PalWorldSettings.ini on this host. Checked for changes every time the
# server comes back online after a restart; differences are posted to ALERTS_CHANNEL_ID.
PALWORLD_SETTINGS_INI_PATH=/home/steam/Steam/steamapps/common/PalServer/Pal/Saved/Config/LinuxServer/PalWorldSettings.ini

# --- Palworld service ---
# Name of the systemd unit managing the Palworld dedicated server on this host.
# Defaults to "palworld" if unset — only set this if your unit is named differently
# (e.g. when running multiple Palworld servers on one host).
# PALWORLD_SERVICE_NAME=palworld

# --- Palworld server update ---
# Absolute path steamcmd installs/updates the Palworld dedicated server into
# (passed as +force_install_dir). Must match the install used by PALWORLD_SERVICE_NAME.
PALWORLD_INSTALL_DIR=/home/steam/Steam/steamapps/common/PalServer
# Path to the steamcmd binary. Defaults to /usr/games/steamcmd (apt install location) if unset.
# STEAMCMD_PATH=/usr/games/steamcmd

# --- In-game @swee assistant (optional) ---
# Leave ANTHROPIC_API_KEY unset to disable the feature entirely — @swee chat
# mentions are then left as ordinary unhandled chat lines.
# ANTHROPIC_API_KEY=
# Required if ANTHROPIC_API_KEY is set: Discord channel for the question/answer audit log.
# ASSISTANT_LOG_CHANNEL_ID=123456789012345678
# Minimum seconds between answered questions from the same player. Defaults to 30.
# ASK_COOLDOWN_SEC=30
